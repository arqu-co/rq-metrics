        {
          "file": "devops/terraform/modules/cloud_front/locals.tf",
          "line": 13,
          "severity": "high",
          "category": "correctness",
          "title": "ACM certificate may not cover app.${env}.arqu.co for non-prod environments",
          "body": "Line 7 now adds app.${var.environment}.arqu.co as a CloudFront alias for non-prod. CloudFront requires the viewer certificate to cover every alias it serves. The non-prod certificate ARNs are hardcoded (staging: 51ba1095, dev: 1d443118). If these are single-name or limited-SAN certs that only cover webapp.${env}.arqu.co and not app.${env}.arqu.co, CloudFront will reject the distribution update with a certificate-mismatch error. Fix: verify each non-prod ACM cert covers app.staging.arqu.co and app.development.arqu.co (either as explicit SANs or as a wildcard like *.staging.arqu.co / *.development.arqu.co). If not, add those SANs to the certs before applying.",
          "confidence": "medium"
        }
      ]
    },
