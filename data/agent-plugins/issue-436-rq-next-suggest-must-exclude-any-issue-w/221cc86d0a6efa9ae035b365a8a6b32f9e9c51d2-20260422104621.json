      "findings_details": [
        {
          "file": "plugins/rq/scripts/lib/issue-progress-signals.sh",
          "line": 13,
          "severity": "medium",
          "category": "correctness",
          "title": "fetch_open_pr_issue_refs silently truncates at 100 PRs",
          "body": "gh pr list -L 100 silently drops open PRs beyond the 100th. For repos with >100 open PRs, active-work signals on those PRs are never detected. An issue referenced by PR #101+ will appear as a free candidate and be offered for binding, causing concurrent-session collision. Fix: use the gh API pagination or set -L to a larger bound (e.g. 500) with a comment explaining the cap.",
          "confidence": "high"
        },
        {
          "file": "plugins/rq/scripts/test_rq_next_suggest_harness.sh",
          "line": 135,
          "severity": "medium",
          "category": "test-quality",
          "title": "plan-claim.sh stub in make_full_gh_stub is dead code",
          "body": "The stub writes plan-claim.sh into $stub_dir and puts $stub_dir on PATH, but rq-next-suggest.sh invokes plan-claim.sh via absolute path (sd + '/plan-claim.sh' where sd=SCRIPT_DIR). The PATH-based stub is never called. Tests silently use the real plan-claim.sh with --local-only, which happens to return 'unclaimed' for the test issue numbers. This is a fragile implicit dependency: if a real worktree or branch named issue-999-* or issue-100-* exists in the repo, the test will incorrectly block those candidates. Fix: export SCRIPT_DIR pointing to a temp stub dir that contains the plan-claim.sh stub, or pass an env var the script can use to override the plan-claim.sh path.",
          "confidence": "high"
        }
      ]
    },
