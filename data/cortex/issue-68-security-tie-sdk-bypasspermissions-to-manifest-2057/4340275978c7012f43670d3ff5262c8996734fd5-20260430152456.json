      "findings_details": [
        {
          "file": "lib/runtime/sdk-options.test.ts",
          "line": 20,
          "severity": "low",
          "category": "style",
          "title": "Test name leaks implementation technique via parenthetical '(Object.hasOwn)'",
          "body": "Line 20: 'omits bypass flags when trusted is false (Object.hasOwn)' embeds the assertion technique in the test name rather than describing behavior. Test names should say what the system does, not how the test verifies it. The other four tests in this describe block follow the pure-behavior pattern ('includes bypass flags when trusted is true', 'omits abortController when no signal is supplied'). Fix: rename to 'omits bypass flags entirely when trusted is false' \u2014 the Object.hasOwn detail is already visible in the test body for anyone reading it.",
          "confidence": "high"
        }
      ]
    },
    "review-wip-reviewer-68": {
